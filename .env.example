# ============================================
# 股票量化交易分析系统 - 环境变量配置
# 复制为 .env 并填入真实值
# ============================================

# ---- 服务端口 ----
PORT=3000
NODE_ENV=development

# ---- MongoDB ----
# 本地: mongodb://localhost:27017/stock_quant
# 远程(带认证): mongodb://user:pass@host:27017/stock_quant?authSource=admin
MONGO_URI=mongodb://admin:Qa369*@120.77.9.130:27017/stock_quant?authSource=admin

# ---- Redis (可选，不配则跳过) ----
# REDIS_URL=redis://localhost:6379
SKIP_REDIS=true

# ---- JWT ----
JWT_SECRET=your_jwt_secret_at_least_32_characters_long
JWT_REFRESH_SECRET=another_secret_for_refresh_token_32chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---- AI LLM API Keys ----
# 至少配一个即可，优先推荐 DeepSeek (国内直连、便宜)
DEEPSEEK_API_KEY=sk-xxx
CLAUDE_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx

# ---- AI 模型路由 (按场景自动选择模型) ----
AI_PROVIDER_ANALYSIS=deepseek
AI_PROVIDER_STRATEGY=deepseek
AI_PROVIDER_CHAT=deepseek
AI_PROVIDER_MARKET=deepseek
AI_PROVIDER_VISION=deepseek

# ---- AI 成本控制 ----
AI_DAILY_TOKEN_LIMIT=500000
AI_VISION_DAILY_LIMIT=30

# ---- 数据采集 ----
# 可选，AKShare 免费接口不需要 token
# TUSHARE_TOKEN=your_tushare_token

# ---- 前端地址 (CORS) ----
CLIENT_URL=http://localhost:5173
